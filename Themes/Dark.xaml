<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="Bg.Window"        Color="#1E1E1E"/>
    <SolidColorBrush x:Key="Bg.Header"        Color="#2D2D2D"/>
    <SolidColorBrush x:Key="Bg.Panel"         Color="#252526"/>
    <SolidColorBrush x:Key="Bg.Item"          Color="#2D2D2D"/>
    <SolidColorBrush x:Key="Bg.ItemHover"     Color="#3A3D41"/>
    <SolidColorBrush x:Key="Bg.ItemSelected"  Color="#264F78"/>
    <SolidColorBrush x:Key="Bg.Button"        Color="#2D2D2D"/>
    <SolidColorBrush x:Key="Bg.ButtonHover"   Color="#3A3A3A"/>
    <SolidColorBrush x:Key="Bg.ButtonPress"   Color="#454545"/>
    <SolidColorBrush x:Key="Bg.DeleteHover"   Color="#5A1515"/>

    <SolidColorBrush x:Key="Border.Panel"     Color="#3F3F3F"/>
    <SolidColorBrush x:Key="Border.Item"      Color="#3F3F3F"/>

    <SolidColorBrush x:Key="Fg.Primary"       Color="#D4D4D4"/>
    <SolidColorBrush x:Key="Fg.Secondary"     Color="#9E9E9E"/>
    <SolidColorBrush x:Key="Fg.Muted"         Color="#6D6D6D"/>
    <SolidColorBrush x:Key="Fg.TabHover"      Color="#D4D4D4"/>
    <SolidColorBrush x:Key="Fg.Button"        Color="#D4D4D4"/>
    <SolidColorBrush x:Key="Fg.Label"         Color="#9E9E9E"/>

</ResourceDictionary>
