<Window x:Class="CHistory_VS.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CHistory – Settings" Height="210" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False" Background="#F5F5F5">
    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#424242"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F5F5F5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EEEEEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1E1E1E" Padding="16,12">
            <TextBlock Foreground="White" FontSize="14" FontWeight="SemiBold">
                <Run Text="C" Foreground="#4FC3F7"/><Run Text="History – Settings"/>
            </TextBlock>
        </Border>

        <!-- Settings rows -->
        <StackPanel Grid.Row="1" Margin="16,14,16,10">

            <!-- Hotkey -->
            <DockPanel Margin="0,0,0,12">
                <TextBlock Text="Hotkey" Foreground="#616161" FontSize="12"
                           VerticalAlignment="Center" Width="130"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border x:Name="HotkeyBorder" BorderBrush="#E0E0E0" BorderThickness="1"
                            CornerRadius="3" Padding="7,3">
                        <TextBlock x:Name="HotkeyLabel" FontSize="12" Foreground="#424242"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <Button x:Name="ChangeHotkeyButton" Content="&#x270E;" Margin="6,0,0,0"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#9E9E9E" FontSize="13" Cursor="Hand"
                            VerticalAlignment="Center" ToolTip="Click then press your shortcut"
                            Click="ChangeHotkey_Click"/>
                </StackPanel>
            </DockPanel>

            <!-- Max history items -->
            <DockPanel>
                <TextBlock Text="Max history items" Foreground="#616161" FontSize="12"
                           VerticalAlignment="Center" Width="130"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBox x:Name="MaxItemsBox" Width="52" FontSize="12"
                             VerticalAlignment="Center" TextAlignment="Center"
                             BorderBrush="#E0E0E0" BorderThickness="1"
                             Padding="4,3"/>
                    <Button Content="Apply" Margin="6,0,0,0"
                            Style="{StaticResource ActionButtonStyle}"
                            VerticalAlignment="Center"
                            Click="ApplyMax_Click"/>
                </StackPanel>
            </DockPanel>

        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="12,8">
            <Button Content="Close" HorizontalAlignment="Right"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="Close_Click"/>
        </Border>
    </Grid>
</Window>
