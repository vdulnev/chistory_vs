<Window x:Class="CHistory_VS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CHistory_VS"
        mc:Ignorable="d"
        Title="CHistory - Clipboard Manager" Height="620" Width="480"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        Background="{DynamicResource Bg.Window}">
    <Window.Resources>
        <!-- Favorite button style -->
        <Style x:Key="FavoriteButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Content" Value="&#x2606;"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg.Muted}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                    <Setter Property="Content" Value="&#x2605;"/>
                    <Setter Property="Foreground" Value="#FFC107"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Delete button style -->
        <Style x:Key="DeleteButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg.Muted}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="11">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Bg.DeleteHover}"/>
                                <Setter Property="Foreground" Value="#E53935"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Footer button style -->
        <Style x:Key="FooterButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Background" Value="{DynamicResource Bg.Button}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Panel}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg.Button}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Bg.ButtonHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Bg.ButtonPress}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab button style -->
        <Style x:Key="TabButtonStyle" TargetType="RadioButton">
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg.Secondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent"
                                BorderBrush="Transparent" BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4FC3F7"/>
                                <Setter Property="Foreground" Value="#4FC3F7"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource Fg.TabHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListViewItem style -->
        <Style TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" Background="{DynamicResource Bg.Item}"
                                BorderBrush="{DynamicResource Border.Item}" BorderThickness="0,0,0,1"
                                Cursor="Hand">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Bg.ItemHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Bg.ItemSelected}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource Bg.Header}" Padding="16,14">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="C" Foreground="#4FC3F7" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="History" Foreground="White" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
                <TextBlock x:Name="MonitoringStatus" DockPanel.Dock="Right"
                           Text="&#x25CF; Monitoring" Foreground="#4CAF50"
                           FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- Tab bar -->
        <Border Grid.Row="1" Background="{DynamicResource Bg.Panel}"
                BorderBrush="{DynamicResource Border.Panel}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="AllTab" Content="History"
                             Style="{StaticResource TabButtonStyle}"
                             IsChecked="True"
                             Checked="AllTab_Checked"/>
                <RadioButton x:Name="FavoritesTab" Content="Favorites"
                             Style="{StaticResource TabButtonStyle}"
                             Checked="FavoritesTab_Checked"/>
            </StackPanel>
        </Border>

        <!-- Search bar -->
        <Border Grid.Row="2" Background="{DynamicResource Bg.Panel}"
                BorderBrush="{DynamicResource Border.Panel}" BorderThickness="0,0,0,1" Padding="12,9">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="&#x1F50D;" FontSize="13"
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{DynamicResource Fg.Secondary}"/>
                <TextBox Grid.Column="1" x:Name="SearchBox"
                         BorderThickness="0" Background="Transparent"
                         FontSize="13" VerticalAlignment="Center"
                         Foreground="{DynamicResource Fg.Primary}"
                         CaretBrush="{DynamicResource Fg.Primary}"
                         TextChanged="SearchBox_TextChanged"/>
                <TextBlock Grid.Column="1" x:Name="SearchPlaceholder"
                           Text="Search clipboard history..."
                           Foreground="{DynamicResource Fg.Muted}"
                           FontSize="13" VerticalAlignment="Center" IsHitTestVisible="False"/>
                <Button Grid.Column="2" x:Name="ClearSearchButton"
                        Content="&#x2715;" Visibility="Collapsed"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource Fg.Secondary}" FontSize="13" Cursor="Hand"
                        VerticalAlignment="Center" Margin="4,0,0,0"
                        Click="ClearSearch_Click"/>
            </Grid>
        </Border>

        <!-- History list -->
        <ListView Grid.Row="3" x:Name="HistoryList"
                  Background="Transparent" BorderThickness="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  VirtualizingPanel.IsVirtualizing="True"
                  SelectionChanged="HistoryList_SelectionChanged"
                  MouseDoubleClick="HistoryList_MouseDoubleClick"
                  KeyDown="HistoryList_KeyDown">
            <ListView.ItemTemplate>
                <DataTemplate DataType="{x:Type local:ClipboardEntry}">
                    <Grid Margin="14,10,10,10" ToolTip="{Binding Text}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Preview}"
                                   FontSize="13" Foreground="{DynamicResource Fg.Primary}"
                                   TextWrapping="Wrap"
                                   MaxHeight="58"
                                   TextTrimming="CharacterEllipsis"
                                   LineHeight="18"/>

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="{Binding DisplayTime}"
                                   FontSize="11" Foreground="{DynamicResource Fg.Secondary}"
                                   Margin="0,4,0,0"/>

                        <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                Style="{StaticResource FavoriteButtonStyle}"
                                VerticalAlignment="Center"
                                Margin="8,0,2,0"
                                Click="FavoriteItem_Click"
                                Tag="{Binding}"/>

                        <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                                Content="&#x2715;"
                                Style="{StaticResource DeleteButtonStyle}"
                                VerticalAlignment="Center"
                                Margin="2,0,2,0"
                                Click="DeleteItem_Click"
                                Tag="{Binding}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Empty state -->
        <StackPanel Grid.Row="3" x:Name="EmptyState"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="Collapsed">
            <TextBlock x:Name="EmptyIcon" Text="&#x1F4CB;" FontSize="52"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="EmptyTitle" Text="No clipboard history yet"
                       FontSize="15" Foreground="{DynamicResource Fg.Secondary}"
                       HorizontalAlignment="Center" Margin="0,12,0,0"/>
            <TextBlock x:Name="EmptySubtitle" Text="Copy something to get started"
                       FontSize="12" Foreground="{DynamicResource Fg.Muted}"
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="4" Background="{DynamicResource Bg.Panel}"
                BorderBrush="{DynamicResource Border.Panel}" BorderThickness="0,1,0,0" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Clear All"
                        Style="{StaticResource FooterButtonStyle}"
                        Click="ClearAll_Click"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="CountLabel" Text="0 items"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Fg.Secondary}" FontSize="12"/>
                    <Button Content="&#x2699;" Margin="10,0,0,0"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource Fg.Secondary}" FontSize="15" Cursor="Hand"
                            VerticalAlignment="Center" ToolTip="Settings"
                            Click="Settings_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
