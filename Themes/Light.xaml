<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="Bg.Window"        Color="#F5F5F5"/>
    <SolidColorBrush x:Key="Bg.Header"        Color="#1E1E1E"/>
    <SolidColorBrush x:Key="Bg.Panel"         Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Bg.Item"          Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Bg.ItemHover"     Color="#F0F7FF"/>
    <SolidColorBrush x:Key="Bg.ItemSelected"  Color="#DDEEFF"/>
    <SolidColorBrush x:Key="Bg.Button"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Bg.ButtonHover"   Color="#F5F5F5"/>
    <SolidColorBrush x:Key="Bg.ButtonPress"   Color="#EEEEEE"/>
    <SolidColorBrush x:Key="Bg.DeleteHover"   Color="#FFEBEE"/>

    <SolidColorBrush x:Key="Border.Panel"     Color="#E0E0E0"/>
    <SolidColorBrush x:Key="Border.Item"      Color="#EEEEEE"/>

    <SolidColorBrush x:Key="Fg.Primary"       Color="#212121"/>
    <SolidColorBrush x:Key="Fg.Secondary"     Color="#9E9E9E"/>
    <SolidColorBrush x:Key="Fg.Muted"         Color="#BDBDBD"/>
    <SolidColorBrush x:Key="Fg.TabHover"      Color="#424242"/>
    <SolidColorBrush x:Key="Fg.Button"        Color="#424242"/>
    <SolidColorBrush x:Key="Fg.Label"         Color="#616161"/>

</ResourceDictionary>
