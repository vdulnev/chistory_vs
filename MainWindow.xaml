<Window x:Class="CHistory_VS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CHistory_VS"
        mc:Ignorable="d"
        Title="CHistory - Clipboard Manager" Height="620" Width="480"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        Background="#F5F5F5">
    <Window.Resources>
        <!-- Delete button style -->
        <Style x:Key="DeleteButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#BDBDBD"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="11">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFEBEE"/>
                                <Setter Property="Foreground" Value="#E53935"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Footer button style -->
        <Style x:Key="FooterButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#424242"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F5F5F5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EEEEEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListViewItem style -->
        <Style TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" Background="White"
                                BorderBrush="#EEEEEE" BorderThickness="0,0,0,1"
                                Cursor="Hand">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F0F7FF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#DDEEFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1E1E1E" Padding="16,14">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="C" Foreground="#4FC3F7" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="History" Foreground="White" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
                <TextBlock x:Name="MonitoringStatus" DockPanel.Dock="Right"
                           Text="&#x25CF; Monitoring" Foreground="#4CAF50"
                           FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- Search bar -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="12,9">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="&#x1F50D;" FontSize="13"
                           VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#9E9E9E"/>
                <TextBox Grid.Column="1" x:Name="SearchBox"
                         BorderThickness="0" Background="Transparent"
                         FontSize="13" VerticalAlignment="Center"
                         TextChanged="SearchBox_TextChanged"/>
                <TextBlock Grid.Column="1" x:Name="SearchPlaceholder"
                           Text="Search clipboard history..." Foreground="#BDBDBD"
                           FontSize="13" VerticalAlignment="Center" IsHitTestVisible="False"/>
                <Button Grid.Column="2" x:Name="ClearSearchButton"
                        Content="&#x2715;" Visibility="Collapsed"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#9E9E9E" FontSize="13" Cursor="Hand"
                        VerticalAlignment="Center" Margin="4,0,0,0"
                        Click="ClearSearch_Click"/>
            </Grid>
        </Border>

        <!-- History list -->
        <ListView Grid.Row="2" x:Name="HistoryList"
                  Background="Transparent" BorderThickness="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  VirtualizingPanel.IsVirtualizing="True"
                  SelectionChanged="HistoryList_SelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate DataType="{x:Type local:ClipboardEntry}">
                    <Grid Margin="14,10,10,10" ToolTip="{Binding Text}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Preview}"
                                   FontSize="13" Foreground="#212121"
                                   TextWrapping="Wrap"
                                   MaxHeight="58"
                                   TextTrimming="CharacterEllipsis"
                                   LineHeight="18"/>

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="{Binding DisplayTime}"
                                   FontSize="11" Foreground="#9E9E9E"
                                   Margin="0,4,0,0"/>

                        <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                Content="&#x2715;"
                                Style="{StaticResource DeleteButtonStyle}"
                                VerticalAlignment="Center"
                                Margin="8,0,2,0"
                                Click="DeleteItem_Click"
                                Tag="{Binding}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Empty state -->
        <StackPanel Grid.Row="2" x:Name="EmptyState"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="Collapsed">
            <TextBlock x:Name="EmptyIcon" Text="&#x1F4CB;" FontSize="52"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="EmptyTitle" Text="No clipboard history yet"
                       FontSize="15" Foreground="#757575"
                       HorizontalAlignment="Center" Margin="0,12,0,0"/>
            <TextBlock x:Name="EmptySubtitle" Text="Copy something to get started"
                       FontSize="12" Foreground="#BDBDBD"
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="3" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="12,8">
            <DockPanel>
                <Button DockPanel.Dock="Left" Content="Clear All"
                        Style="{StaticResource FooterButtonStyle}"
                        Click="ClearAll_Click"/>
                <TextBlock x:Name="CountLabel" Text="0 items"
                           VerticalAlignment="Center" HorizontalAlignment="Right"
                           Foreground="#9E9E9E" FontSize="12"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
